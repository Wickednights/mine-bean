# Backend API URL (browser requests)
# For development (local backend):
NEXT_PUBLIC_API_URL=http://localhost:3001

# For Docker: docker-compose sets this automatically
# For production (deployed backend):
# NEXT_PUBLIC_API_URL=https://api.minebean.io

# Server-side backend URL (Next.js API routes calling backend)
# For Docker: use http://backend:3001 so frontend container can reach backend
# For local dev without Docker: omit — falls back to NEXT_PUBLIC_API_URL or localhost:3001
# INTERNAL_API_URL=http://backend:3001

# Supabase (for profile storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Docker: Create .env with Supabase keys (optional) before running docker compose up
