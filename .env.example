# Backend API URL
# For development (local backend):
NEXT_PUBLIC_API_URL=http://localhost:3001

# For Docker: docker-compose sets this automatically
# For production (deployed backend):
# NEXT_PUBLIC_API_URL=https://api.minebean.io

# Supabase (for profile storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Docker: Create .env with Supabase keys (optional) before running docker compose up
