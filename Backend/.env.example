# Backend port — must match frontend NEXT_PUBLIC_API_URL (e.g. http://localhost:3001)
PORT=3001

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/minebean

# BSC RPC — use testnet for testnet, mainnet for production
# Public (rate limited): https://bsc-testnet-dataseed.bnbchain.org
# For fewer rate limit errors, use Alchemy/QuickNode/Infura BSC testnet URL with API key
RPC_URL=https://bsc-testnet-dataseed.bnbchain.org

# Indexer poll interval (ms). Default 12000 (12s). Higher = fewer RPC calls, slower event indexing.
# INDEXER_POLL_INTERVAL_MS=12000

# Auto-reset: automatically call reset() when a round ends. Requires a wallet funded with BNB for gas.
# RESET_WALLET_PRIVATE_KEY=0x...
# AUTO_RESET_POLL_INTERVAL_MS=12000
# AUTO_RESET_ENABLED=false  # set to false to disable

# Contract addresses (BSC Testnet - update after redeploy)
GRIDMINING_ADDRESS=0x268Cac7cCEFa8F542a3B64002D66Edc3d6C930FB
BEAN_ADDRESS=0x89BeA6C663D33b129525F14574b8eFdC1d19A39c
AUTOMINER_ADDRESS=0xCdB629B6E58BBae482adfE49B9886a6a1BBD7304
TREASURY_ADDRESS=0x90bAbE945cffaA081a3853acFeAe1c97cEf726F4
STAKING_ADDRESS=0xeDcA64d1620D544Ac0184467CAc24867e682Bdc7
